MIRA_API_URL=http://localhost:8000
BETA=false
# Dev only — port for the desktop renderer Vite server (default 59247; avoids common ports like 5173).
# If you change this, Vite, Electron, and `npm run dev` wait logic all read it from here.
# MIRA_RENDERER_DEV_PORT=59247
# Optional: full URL Electron opens in dev (defaults to http://127.0.0.1:<MIRA_RENDERER_DEV_PORT>).
# MIRA_RENDERER_DEV_URL=http://127.0.0.1:59247
