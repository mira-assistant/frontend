{
  "name": "dadei-desktop",
  "version": "4.0.2",
  "author": {
    "name": "Ankur Desai",
    "email": "ardusa05@gmail.com",
    "url": "https://ardusa.dev/"
  },
  "main": "dist/main/background.js",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n \"VITE,MAIN,ELEC\" -c \"magenta,blue,green\" \"vite --config renderer/vite.config.ts\" \"tsc -p main/tsconfig.json --watch\" \"node scripts/wait-renderer.mjs && cross-env NODE_ENV=development electron .\"",
    "build": "rimraf dist renderer/dist && vite build --config renderer/vite.config.ts && tsc -p main/tsconfig.json",
    "start": "cross-env NODE_ENV=production electron .",
    "package": "npm run build && electron-builder --publish never",
    "clean": "rimraf dist renderer/dist release"
  },
  "dependencies": {
    "@dadei/ui": "*",
    "@ricky0123/vad-react": "^0.0.36",
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.23.24",
    "keytar": "^7.9.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.9.5",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@electron/rebuild": "^3.6.0",
    "@tailwindcss/postcss": "^4",
    "@types/keytar": "^4.4.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "39.8.8",
    "electron-builder": "^26.0.12",
    "rimraf": "^6.1.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^7.2.2",
    "wait-on": "^9.0.3"
  }
}
