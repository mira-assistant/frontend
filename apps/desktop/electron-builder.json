{
  "electronVersion": "39.8.8",
  "appId": "com.dadei.app",
  "productName": "Dadei Assistant",
  "copyright": "Copyright © 2026 Ankur Desai",
  "artifactName": "Dadei-Assistant-${version}-${os}-${arch}.${ext}",
  "files": [
    "dist/**/*",
    "renderer/dist/**/*",
    "package.json",
    ".env.production"
  ],
  "directories": {
    "buildResources": "resources",
    "output": "release"
  },
  "asar": true,
  "publish": {
    "provider": "github",
    "owner": "dadei-assistant",
    "repo": "dadei-frontend"
  },
  "win": {
    "target": "nsis",
    "icon": "resources/icon.png"
  },
  "mac": {
    "target": "dmg",
    "icon": "resources/icon.png"
  }
}
