{
  "electronVersion": "39.8.8",
  "appId": "com.dadei.app",
  "productName": "Dadei Assistant",
  "copyright": "Copyright © 2026 Ankur Desai",
  "artifactName": "Dadei-Assistant-${version}-${os}-${arch}.${ext}",
  "afterSign": "scripts/notarize.cjs",
  "extraResources": [
    {
      "from": "resources/updater.html",
      "to": "."
    }
  ],
  "files": [
    "dist/**/*",
    "renderer/dist/**/*",
    "package.json",
    ".env.production"
  ],
  "directories": {
    "buildResources": "resources",
    "output": "release"
  },
  "asar": true,
  "publish": {
    "provider": "github",
    "owner": "dadei-assistant",
    "repo": "dadei-frontend"
  },
  "win": {
    "target": "nsis",
    "icon": "resources/icon.png"
  },
  "nsis": {
    "differentialPackage": false
  },
  "mac": {
    "target": ["dmg", "zip"],
    "icon": "resources/icon.png",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "resources/entitlements.mac.plist",
    "entitlementsInherit": "resources/entitlements.mac.inherit.plist"
  },
  "linux": {
    "target": ["AppImage"],
    "icon": "resources/icon.png",
    "category": "Utility"
  }
}
